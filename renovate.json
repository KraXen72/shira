{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackageNames": ["yt-dlp"],
      "matchUpdateTypes": ["major", "minor", "patch"],
      "enabled": true
    }
  ]
}
